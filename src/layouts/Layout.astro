<style>
	@keyframes scroll {
		0% {
			transform: translate(0);
		}
		to {
			transform: translate(-50%);
		}
	}
	.animate-scroll {
		will-change: transform;
		width: -moz-fit-content;
		width: fit-content;
		animation: 60s linear infinite scroll;
		display: flex;
	}
	@keyframes slide-down {
		0% {
			transform: translateY(-100%);
		}
		to {
			transform: translateY(0);
		}
	}
	@keyframes slide-up {
		0% {
			transform: translateY(0);
		}
		to {
			transform: translateY(-100%);
		}
	}
	@keyframes slide-up-banner {
		0% {
			opacity: 0;
			transform: translateY(100%);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	.menu-slide-down {
		animation: 0.3s ease-out slide-down;
	}
	.menu-slide-up {
		animation: 0.3s ease-out slide-up;
	}
	.animate-slide-up {
		animation: 0.4s ease-out slide-up-banner;
	}
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.animate-bounce-gift {
		animation: 2s ease-in-out infinite giftBounce;
	}
	@keyframes giftBounce {
		0%,
		to {
			transform: translateY(0);
		}
		25% {
			transform: translateY(-4px);
		}
		50% {
			transform: translateY(0);
		}
		75% {
			transform: translateY(-2px);
		}
	}
</style>
